{
  "name": "agentcohort",
  "version": "0.9.0",
  "description": "Install a principal/staff-level Claude Code AI software engineering organization (agents + workflows + routing rules) into any project with one command.",
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "subagents",
    "workflow",
    "ai",
    "cli",
    "developer-tools",
    "code-review",
    "bug-audit"
  ],
  "license": "MIT",
  "author": "agentcohort",
  "type": "commonjs",
  "bin": {
    "agentcohort": "dist/cli.js",
    "agent-force": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thiendekaco/agentcohort.git"
  },
  "homepage": "https://github.com/Thiendekaco/agentcohort#readme",
  "bugs": {
    "url": "https://github.com/Thiendekaco/agentcohort/issues"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "sync-boot": "node scripts/sync-boot-directive.mjs",
    "build": "npm run clean && tsc -p tsconfig.json && npm run sync-boot && node scripts/copy-templates.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  }
}
